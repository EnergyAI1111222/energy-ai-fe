import { clerkMiddleware, createRouteMatcher } from "@clerk/nextjs/server";
import { NextResponse } from "next/server";

// Public routes: sign-in/sign-up pages only (no auth required)
const isPublicRoute = createRouteMatcher([
  '/sign-in(.*)',
  '/sign-up(.*)',
]);

// Data routes that require authentication
const isProtectedRoute = createRouteMatcher([
  '/eu(.*)',
  '/catalog(.*)',
  '/datasets(.*)',
  '/settings(.*)',
  '/export-data(.*)',
  '/picasso(.*)',
  '/billing(.*)',
  '/futures(.*)',
  '/gas(.*)',
  '/insights(.*)',
  '/alerts(.*)',
  '/record-tracker(.*)',
  '/nodal-analyse(.*)',
  '/retail(.*)',
  '/imbalance-capacity(.*)',
  '/custom-dashboards(.*)',
  '/my-grid(.*)',
]);

export default clerkMiddleware(async (auth, request) => {
  // 1. Check if Clerk is configured. If not, bypass for local dev/testing.
  if (!process.env.NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY || process.env.NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY === 'pk_test_placeholder') {
    return NextResponse.next();
  }

  // 2. Stealth password wall for external demos
  if (process.env.STEALTH_PASSWORD) {
    const basicAuth = request.headers.get('authorization');
    let isAuthenticated = false;
    if (basicAuth) {
      const authValue = basicAuth.split(' ')[1];
      const decodedValue = atob(authValue);
      // We accept any username, only the password matters.
      const [_user, pwd] = decodedValue.split(':');
      if (pwd === process.env.STEALTH_PASSWORD) {
        isAuthenticated = true;
      }
    }

    if (!isAuthenticated) {
      return new NextResponse("Unauthorized", { 
        status: 401, 
        headers: { 'WWW-Authenticate': 'Basic realm="Secure Area"' } 
      });
    }
  }

  // 3. Require sign-in for all data routes
  if (isProtectedRoute(request)) {
    await auth.protect();
  }
});

export const config = {
  matcher: [
    '/((?!_next|[^?]*\\.(?:html?|css|js(?!on)|jpe?g|webp|png|gif|svg|ttf|woff2?|ico|csv|docx?|xlsx?|zip|webmanifest)).*)',
    '/(api|trpc)(.*)',
  ],
};
